---
import SectionLayout from "../layouts/section-layout.astro";
---

<SectionLayout title="Our Venue" id="event">
  <Fragment slot="content">
    <div class="event-layout">
      <div class="venue-copy">
        <h3 class="venue-subheading">Harris Theater</h3>
        <p class="venue-text">
          Our festival takes place at the Harris Theater in downtown Pittsburgh's Cultural District, a beloved art-house cinema operated by the Pittsburgh Cultural Trust.
        </p>
        <p class="venue-text">
          The historic marquee and Liberty Avenue entrance give the day a real sense of occasion before audiences head inside for films, Q&amp;As, live comedy, and cookies.
        </p>
      </div>

      <div class="venue-image-wrap">
        <img
          src="/assets/2026-event-photos/harris-theater-marquee.jpg"
          alt="The Harris Theater marquee outside the Cookies & Comedy Film Festival"
          class="venue-image"
        />
      </div>
    </div>
  </Fragment>
</SectionLayout>

<style>
  .event-layout {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }

  .venue-copy {
    max-width: 760px;
    text-align: center;
  }

  .venue-subheading {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--color-secondary);
    margin: 0 0 1rem 0;
  }

  .venue-text {
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0 0 1rem 0;
  }

  .venue-image-wrap {
    width: 100%;
    max-width: 1040px;
  }

  .venue-image {
    width: 100%;
    display: block;
    border-radius: 1rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  @media (min-width: 1100px) {
    .event-layout {
      gap: 2.5rem;
    }

    .venue-copy {
      max-width: 820px;
    }
  }
</style>
