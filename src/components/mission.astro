---
import SectionLayout from "../layouts/section-layout.astro";
import Timeline from "./event/Timeline.astro";
import Testimonial from "./event/Testimonial.astro";

const timelineItems = [
  { title: "Film Submissions", date: "June 1 - December 31, 2026" },
  { title: "Schedule Announcement", date: "January 14, 2027" },
  { title: "Festival Day", date: "March 2027 (Day TBD)" },
];

const testimonials = [
  {
    quote:
      "Films were screened in a wonderful venue in the middle of Pittsburgh with a lively and large crowd. The communication was among the best I have experienced, and Q&As followed every block with plenty of time for networking.",
    author: "Steve Nerangis",
    context: "Tech Rehearsal",
  },
  {
    quote:
      "From start to finish, the communication with this festival was top-notch. Scott provided personalized care and attention in his outreach, and I'm very proud that a festival of this quality has become established in Pittsburgh.",
    author: "Rocky Paterra",
    context: "Gaslighting Dad",
  },
];

---

<SectionLayout title="About" id="mission">
  <Fragment slot="content">
    <div class="mission-layout">
      <div class="mission-content">
        <div class="mission-intro">
          <p>
            The 2026 Cookies & Comedy Film Festival was a blast! On <strong>Saturday, March 14, 2026</strong>, we packed the Harris Theater in downtown Pittsburgh with over 40 comedy films from around the world, live comedy performances, and of course - cookies!
          </p>
          <p>
            We're turning Pittsburgh into a comedy powerhouse! Our festival featured top-notch comedy short films from our own yinzers and funny folks from all over the globe. Here's what went dahn:
          </p>
        </div>
        
        <div class="mission-features">
          <div class="video-container">
            <iframe
              src="https://www.youtube.com/embed/NzoJCBI6rlc?si=uUV42A9slHe7YOzK"
              title="Cookies & Comedy Film Festival Promo"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        </div>
        
        <!-- What to Expect Section -->
        <div class="experience-section">
          <h3 class="experience-title">What to Expect at Our Festival</h3>

          <div class="experience-showcase">
            <div class="experience-row">
              <div class="experience-copy">
                <p class="experience-kicker">Live Performance</p>
                <p class="experience-caption">Standup comedy and improvised music woven into each film block</p>
              </div>
              <div class="experience-photo-wrap experience-photo-wrap-compact">
                <img
                  src="/assets/2026-event-photos/live-comedy-stage.jpg"
                  alt="A comedian performing with a microphone on stage during the 2026 festival"
                  class="experience-photo experience-photo-wide"
                />
              </div>
            </div>

            <div class="experience-row experience-row-reverse">
              <div class="experience-copy">
                <p class="experience-kicker">Filmmaker Q&amp;A</p>
                <p class="experience-caption">Engaging Q&amp;A sessions with filmmakers</p>
              </div>
              <div class="experience-photo-wrap experience-photo-wrap-feature">
                <img
                  src="/assets/2026-event-photos/qa-stage-panel.jpg"
                  alt="Filmmakers answering audience questions on stage at the 2026 festival"
                  class="experience-photo"
                />
              </div>
            </div>

            <div class="experience-row">
              <div class="experience-copy">
                <p class="experience-kicker">Cookie Table</p>
                <p class="experience-caption">Indulging in homemade cookies throughout the event</p>
              </div>
              <div class="experience-photo-wrap experience-photo-wrap-compact">
                <img
                  src="/assets/2026-event-photos/cookie-enjoying.jpg"
                  alt="A festivalgoer savoring a cookie during the 2026 festival"
                  class="experience-photo"
                />
              </div>
            </div>

            <div class="experience-row experience-row-reverse">
              <div class="experience-copy">
                <p class="experience-kicker">Festival Community</p>
                <p class="experience-caption">Connect with fellow film enthusiasts</p>
              </div>
              <div class="experience-photo-wrap experience-photo-wrap-feature">
                <img
                  src="/assets/2026-event-photos/networking-hallows-eve.jpg"
                  alt="Members of the Hallow's Eve team posing with cookies in the theater lobby"
                  class="experience-photo"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Timeline and Venue Info -->
        <div class="timeline-section">
          <div class="timeline-content">
            <h3 class="timeline-title">Upcoming Timeline</h3>
            <Timeline items={timelineItems} />
          </div>

          <div class="timeline-image-container">
            <img
              src="/assets/2026-event-photos/audience-full-house.jpg"
              alt="A full audience gathered inside the Harris Theater during the 2026 festival"
              class="timeline-img"
            />
          </div>
        </div>

        <!-- Testimonials Section -->
        <div class="testimonial-section">
          <h3 class="testimonial-title">What Our Filmmakers Say</h3>
          <div class="testimonial-container">
            <div class="testimonial-content">
              {testimonials.map((t) => (
                <Testimonial quote={t.quote} author={t.author} context={t.context} />
              ))}
            </div>
            <div class="testimonial-image">
              <img
                src="/assets/2026-event-photos/audience-mood-close.jpg"
                alt="Audience members smiling during a screening at the Harris Theater in 2026"
                class="testimonial-img"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </Fragment>
</SectionLayout>

<style>
  .mission-layout {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .mission-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .mission-intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .mission-features {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  
  .video-container {
    position: relative;
    width: 100%;
    max-width: 650px;
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  
  /* Experience Section */
  .experience-section {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .experience-title {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 1.8rem;
    color: var(--color-secondary);
    margin-bottom: 2rem;
    text-align: center;
  }

  .experience-showcase {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
  }

  .experience-row {
    display: flex;
    gap: 2rem;
    align-items: center;
    justify-content: space-between;
  }

  .experience-row-reverse {
    flex-direction: row-reverse;
  }

  .experience-copy {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 0;
    flex: 0 1 34%;
  }

  .experience-kicker {
    margin: 0;
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(43, 34, 87, 0.72);
  }

  .experience-caption {
    margin: 0;
    font-family: 'Fredoka', sans-serif;
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    line-height: 1.3;
    color: var(--color-secondary);
    font-weight: 600;
  }

  .experience-photo-wrap {
    width: 100%;
    flex: 1 1 auto;
    display: flex;
    justify-content: flex-end;
  }

  .experience-row-reverse .experience-photo-wrap {
    justify-content: flex-start;
  }

  .experience-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    border-radius: 1rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    display: block;
  }

  .experience-photo-wide {
    aspect-ratio: 16 / 9;
    object-position: center 42%;
  }

  .experience-photo-wrap-compact {
    max-width: 460px;
  }

  .experience-photo-wrap-feature {
    max-width: 860px;
  }

  @media (max-width: 860px) {
    .experience-row,
    .experience-row-reverse {
      flex-direction: column;
      gap: 1rem;
    }

    .experience-copy {
      padding: 0;
    }

    .experience-row .experience-copy,
    .experience-row-reverse .experience-copy {
      order: 1;
      text-align: center;
    }

    .experience-row .experience-photo-wrap,
    .experience-row-reverse .experience-photo-wrap {
      max-width: 100%;
      justify-content: center;
    }
  }

  /* Timeline Section */
  .timeline-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 3rem;
    margin-bottom: 2rem;
    align-items: center;
  }

  .timeline-content {
    flex: 1;
    width: 100%;
    max-width: 550px;
  }

  .timeline-title {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 1.8rem;
    color: var(--color-secondary);
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .timeline-image-container {
    flex: 1;
    width: 100%;
    max-width: 820px;
    display: flex;
    justify-content: center;
  }

  .timeline-img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  @media (min-width: 1200px) {
    .timeline-section {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
    }

    .timeline-content {
      max-width: 36%;
    }

    .timeline-image-container {
      max-width: 60%;
    }
  }

  /* Testimonial section styling */
  .testimonial-section {
    margin-top: 3rem;
  }

  .testimonial-title {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 1.8rem;
    color: var(--color-secondary);
    margin-bottom: 2rem;
    text-align: center;
  }

  .testimonial-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: start;
  }

  .testimonial-image {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
  }

  .testimonial-img {
    width: 100%;
    max-width: 980px;
    height: auto;
    border-radius: 0.75rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .testimonial-content {
    display: grid;
    gap: 1.25rem;
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
  }

  @media (min-width: 900px) {
    .testimonial-content {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

</style>
